@page "/search"
@page "/"
@using System.Text.RegularExpressions
@using Shared;
@using Shared.Model
@inject HttpClient Http
@inject IConfiguration Configuration

<h1>Search</h1>

<InputText @bind-Value="query"></InputText>
<button @onclick="OnClickSearch">Search</button>

@if (availableTermNets.Count > 0)
{
    <div style="margin-top: 8px">
        <span>Synonyms:</span>
        @foreach (var net in availableTermNets)
        {
            <label style="margin-left: 12px">
                <input type="checkbox" @onchange="e => ToggleTermNet(net, (bool)e.Value!)" />
                @net
            </label>
        }
    </div>
}

@if (result != null)
{
    <p>Hits: @result.NoOfHits &nbsp;|&nbsp; Time: @result.TimeUsed.ToString()</p>
    <table class="table">
        <tbody>
        @foreach (var dh in result.DocumentHits)
        {
            <tr>
                <td>
                    <a class="link-info" href="" @onclick="() => OnClickDocUrl(dh)" @onclick:preventDefault>
                        @dh.Document.Url</a>
                    (# hits: @dh.Hits.Count)
                </td>
            </tr>
        }
        </tbody>
    </table>
    <div style="margin-top: 8px">
        <button @onclick="PrevPage" disabled="@(currentPage == 0)">← Forrige</button>
        <span style="margin: 0 12px">Side @(currentPage + 1) af @TotalPages</span>
        <button @onclick="NextPage" disabled="@(currentPage + 1 >= TotalPages)">Næste →</button>
    </div>
    <ModalDialog @ref="@modalDialog" Title="Indhold">
        <div class="row">
            <h3>@currentDocumentHit.Document.Url</h3>
            <h4>Hits: @ListToString(currentDocumentHit.Hits) - missing: @ListToString(currentDocumentHit.Missing)</h4>
            <hr>
            <p>@((MarkupString)@fileContent)</p>
            <button class="btn btn-primary" @onclick="() => modalDialog.Close()">Close</button>
        </div>
    </ModalDialog>
}
@code {
    private DocumentHit currentDocumentHit = EmptyDocumentHit();
    private string fileContent = "";
    private string query = "";
    private SearchLogicProxy mLogic = null!;
    private List<string> availableTermNets = new();
    private HashSet<string> selectedTermNets = new();
    private int currentPage = 0;
    private const int pageSize = 10;
    private int TotalPages => result == null ? 1 : (int)Math.Ceiling(result.NoOfHits / (double)pageSize);

    protected override async Task OnInitializedAsync()
    {
        var url = Configuration["ApiBaseUrl"] ?? "";
        mLogic = new SearchLogicProxy(url, Http);
        availableTermNets = await mLogic.GetTermNets();
    }

    private SearchResult? result;

    private static DocumentHit EmptyDocumentHit()
    {
        DocumentHit res = new();
        res.Document = new();
        res.Document.Url = "";
        res.Missing = new();
        res.Hits = new();
        return res;
    }

    private void ToggleTermNet(string net, bool selected)
    {
        if (selected) selectedTermNets.Add(net);
        else selectedTermNets.Remove(net);
    }

    private async Task OnClickSearch()
    {
        currentPage = 0;
        await LoadPage();
    }

    private async Task NextPage()
    {
        currentPage++;
        await LoadPage();
    }

    private async Task PrevPage()
    {
        currentPage--;
        await LoadPage();
    }

    private async Task LoadPage()
    {
        var nets = selectedTermNets.Count > 0 ? selectedTermNets.ToArray() : null;
        result = await mLogic.Search(query.Split(" "), pageSize, nets, currentPage * pageSize);
    }

    private async Task OnClickDocUrl(DocumentHit dh)
    {
        fileContent = await mLogic.GetFileContent(dh.Document.Url);
        foreach (var qWord in query.Split(" "))
            fileContent = Regex.Replace(fileContent, qWord, $"<b>{qWord}</b>");

        currentDocumentHit = dh;
        modalDialog.Open();
    }

    private ModalDialog? modalDialog { get; set; }

    private string ListToString(List<string> s) => s.Count == 0?"[]":$"[{String.Join(',', s)}]";
}
