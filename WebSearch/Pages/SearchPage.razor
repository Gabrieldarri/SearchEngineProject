@page "/search"
@page "/"
@using System.Text.RegularExpressions
@using Shared;
@using Shared.Model
@inject HttpClient Http
@inject IConfiguration Configuration

<div class="search-container">
    <div class="search-header">
        <div class="search-box-wrapper">
            <div class="search-box">
                <InputText @bind-Value="query" @onkeyup="OnKeyUp" placeholder="Search..." />
                <button @onclick="OnClickSearch" class="search-btn">
                    <svg viewBox="0 0 24 24" width="20" height="20">
                        <path fill="currentColor" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                </button>
            </div>
        </div>

        @if (availableTermNets.Count > 0)
        {
            <div class="filters-section">
                <span class="filter-label">Synonyms:</span>
                <div class="filter-options">
                    @foreach (var net in availableTermNets)
                    {
                        <label class="filter-checkbox">
                            <input type="checkbox" @onchange="e => ToggleTermNet(net, (bool)e.Value!)" />
                            <span>@net</span>
                        </label>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="filters-section-empty">
                <span class="filter-label-empty">No synonyms available</span>
            </div>
        }
    </div>

    @if (isLoading && result == null)
    {
        <div class="loading-container">
            <div class="spinner"></div>
            <p>Searching...</p>
        </div>
    }
    else if (result != null)
    {
        <div class="results-header">
            <p class="results-stats">About <strong>@result.NoOfHits</strong> results (<strong>@result.TimeUsed.ToString()</strong>)</p>
        </div>

        <div class="results-list">
            @foreach (var dh in result.DocumentHits)
            {
                <div class="result-item">
                    <h3>
                        <a href="" @onclick="() => OnClickDocUrl(dh)" @onclick:preventDefault>
                            @dh.Document.Url
                        </a>
                    </h3>
                    <p class="result-meta">Hits: @dh.Hits.Count</p>
                </div>
            }
        </div>

        @if (isLoadingPage)
        {
            <div class="loading-container">
                <div class="spinner"></div>
                <p>Loading page...</p>
            </div>
        }
        else
        {
            <div class="pagination">
                <button @onclick="PrevPage" disabled="@(currentPage == 0)" class="pagination-btn">
                    ← Forrige
                </button>
                <span class="page-info">Page @(currentPage + 1) of @TotalPages</span>
                <button @onclick="NextPage" disabled="@(currentPage + 1 >= TotalPages)" class="pagination-btn">
                    Næste →
                </button>
            </div>
        }

        <ModalDialog @ref="@modalDialog" Title="Indhold">
            <div class="modal-content">
                <h3>@currentDocumentHit.Document.Url</h3>
                <p class="modal-meta">Hits: @ListToString(currentDocumentHit.Hits) - missing: @ListToString(currentDocumentHit.Missing)</p>
                <hr>
                <div class="modal-body">
                    @if (isLoadingContent)
                    {
                        <div class="loading-inline">
                            <div class="spinner-small"></div>
                            <p>Loading content...</p>
                        </div>
                    }
                    else
                    {
                        <p>@((MarkupString)@fileContent)</p>
                    }
                </div>
                <button class="btn-close" @onclick="() => modalDialog.Close()">Close</button>
            </div>
        </ModalDialog>
    }
</div>

@code {
    private DocumentHit currentDocumentHit = EmptyDocumentHit();
    private string fileContent = "";
    private string query = "";
    private SearchLogicProxy mLogic = null!;
    private List<string> availableTermNets = new();
    private HashSet<string> selectedTermNets = new();
    private int currentPage = 0;
    private const int pageSize = 10;
    private bool isLoading = false;
    private bool isLoadingPage = false;
    private bool isLoadingContent = false;
    private int TotalPages => result == null ? 1 : (int)Math.Ceiling(result.NoOfHits / (double)pageSize);

    protected override async Task OnInitializedAsync()
    {
        var url = Configuration["ApiBaseUrl"] ?? "";
        mLogic = new SearchLogicProxy(url, Http);
        availableTermNets = await mLogic.GetTermNets();
    }

    private SearchResult? result;

    private static DocumentHit EmptyDocumentHit()
    {
        DocumentHit res = new();
        res.Document = new();
        res.Document.Url = "";
        res.Missing = new();
        res.Hits = new();
        return res;
    }

    private void ToggleTermNet(string net, bool selected)
    {
        if (selected) selectedTermNets.Add(net);
        else selectedTermNets.Remove(net);
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await OnClickSearch();
        }
    }

    private async Task OnClickSearch()
    {
        currentPage = 0;
        await LoadPage(true);
    }

    private async Task NextPage()
    {
        currentPage++;
        await LoadPage(false);
    }

    private async Task PrevPage()
    {
        currentPage--;
        await LoadPage(false);
    }

    private async Task LoadPage(bool isInitialSearch)
    {
        if (isInitialSearch)
            isLoading = true;
        else
            isLoadingPage = true;

        StateHasChanged();

        var nets = selectedTermNets.Count > 0 ? selectedTermNets.ToArray() : null;
        result = await mLogic.Search(query.Split(" "), pageSize, nets, currentPage * pageSize);

        isLoading = false;
        isLoadingPage = false;
        StateHasChanged();
    }

    private async Task OnClickDocUrl(DocumentHit dh)
    {
        isLoadingContent = true;
        StateHasChanged();

        fileContent = await mLogic.GetFileContent(dh.Document.Id);
        foreach (var qWord in query.Split(" "))
            fileContent = Regex.Replace(fileContent, qWord, $"<b>{qWord}</b>");

        currentDocumentHit = dh;
        isLoadingContent = false;
        StateHasChanged();
        modalDialog?.Open();
    }

    private ModalDialog? modalDialog { get; set; }

    private string ListToString(List<string> s) => s.Count == 0?"[]":$"[{String.Join(',', s)}]";
}
